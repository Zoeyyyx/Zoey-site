{
  "manifest_version": 3,
  "name": "Save to Zoey Notes",
  "version": "0.1.0",
  "description": "Manually save selected X posts into Zoey Notes.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://khtyhhgjxwqppakvkdjj.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Zoey Notes",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
